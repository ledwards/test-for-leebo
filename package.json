{
  "name": "swupod",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "node scripts/migrate-on-deploy.js && next build",
    "start": "next start",
    "lint": "eslint .",
    "fetch-cards": "node scripts/fetchCards.js",
    "show-fixes": "node scripts/showFixes.js",
    "migrate": "node scripts/migrate.js dev",
    "migrate:dev": "node scripts/migrate.js dev",
    "migrate:prod": "node scripts/migrate.js prod",
    "migrate:status": "node scripts/migrate.js dev status && node scripts/migrate.js prod status",
    "test": "npm run test:utils && npm run test:belts && npm run test:fixes && npm run test:draft",
    "test:summary": "bash scripts/run-tests.sh",
    "test:belts": "node src/belts/BaseBelt.test.js && node src/belts/CommonBelt.test.js && node src/belts/FoilBelt.test.js && node src/belts/HyperfoilBelt.test.js && node src/belts/HyperspaceBelts.test.js && node src/belts/LeaderBelt.test.js && node src/belts/RareLegendaryBelt.test.js && node src/belts/ShowcaseLeaderBelt.test.js && node src/belts/UncommonBelt.test.js",
    "test:utils": "node src/utils/boosterPack.test.js",
    "test:draft": "node src/utils/draftLogic.test.js",
    "test:fixes": "node src/utils/cardFixes.test.js",
    "test:data": "node src/data/cards.test.js; node src/data/cardCounts.test.js",
    "test:counts": "node src/data/cardCounts.test.js",
    "qa": "node src/qa/packGeneration.test.js"
  },
  "dependencies": {
    "@vercel/postgres": "^0.10.0",
    "cookie": "^1.1.1",
    "dotenv": "^17.2.3",
    "jsonwebtoken": "^9.0.3",
    "nanoid": "^5.1.6",
    "next": "^16.1.3",
    "pg": "^8.11.3",
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/cookie": "^0.6.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0"
  }
}
