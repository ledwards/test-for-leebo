# ============================================
# Protect the Pod - Environment Variables
# ============================================
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to version control (it's in .gitignore)

# ============================================
# Database Configuration
# ============================================
# PostgreSQL connection string
# Get from: Vercel Dashboard → Storage → Your Database → Connection String
# Format: postgresql://user:password@host:port/database
POSTGRES_URL=postgresql://user:password@localhost:5432/protectthepod

# Optional: Separate development database URL
# If not set, POSTGRES_URL will be used for both dev and prod
# POSTGRES_URL_DEV=postgresql://user:password@dev-host:5432/protectthepod_dev

# Legacy alias (some tools may use this)
# DATABASE_URL=postgresql://user:password@localhost:5432/protectthepod

# ============================================
# Application Configuration
# ============================================
# Base URL of your application
# For local development: http://localhost:3000 (or port Vercel uses)
# For production: https://your-domain.vercel.app
APP_URL=http://localhost:3000

# ============================================
# Discord OAuth Configuration
# ============================================
# Get these from: https://discord.com/developers/applications
# 1. Create a new application
# 2. Go to OAuth2 → General
# 3. Copy Client ID and Client Secret
# 4. Add redirect URI: ${APP_URL}/api/auth/callback/discord
DISCORD_CLIENT_ID=your_discord_client_id_here
DISCORD_CLIENT_SECRET=your_discord_client_secret_here

# ============================================
# Discord Bot (Beta Access Check)
# ============================================
# Used to check if a user has the Patreon patron or Friend of the Pod role.
# Setup:
#   1. In Discord Developer Portal, enable the Bot section for your app
#   2. Enable "Server Members Intent" under Bot → Privileged Gateway Intents
#   3. Invite bot to server with guilds.members.read permission
#   4. Copy Bot Token from Bot section
#   5. Get Guild ID: enable Developer Mode in Discord, right-click server → Copy ID
#   6. Get Role ID: Server Settings → Roles → right-click role → Copy ID
DISCORD_BOT_TOKEN=your_discord_bot_token_here
DISCORD_GUILD_ID=your_discord_server_id_here
DISCORD_PATRON_ROLE_ID=your_patron_role_id_here
DISCORD_FRIEND_ROLE_ID=your_friend_of_the_pod_role_id_here

# ============================================
# Authentication & Security
# ============================================
# JWT secret for signing authentication tokens
# Generate a secure random string with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# IMPORTANT: Use a different secret for production!
JWT_SECRET=change-me-to-a-random-secret-string

# Alternative: NextAuth secret (if using NextAuth.js)
# NEXTAUTH_SECRET=change-me-to-a-random-secret-string

# ============================================
# Optional: Google OAuth (Not Yet Implemented)
# ============================================
# Uncomment when Google OAuth is implemented
# GOOGLE_CLIENT_ID=your_google_client_id
# GOOGLE_CLIENT_SECRET=your_google_client_secret

# ============================================
# Optional: API Configuration
# ============================================
# Custom API base URL (if different from APP_URL)
# VITE_API_URL=/api

NEXT_PUBLIC_SITE_URL=https://www.protectthepod.com
# Stats page filter - exclude data before position-based tracking was fixed
# Set to the date when proper slot_type tracking was deployed
NEXT_PUBLIC_STATS_START_DATE=2026-02-12

# ============================================
# Analytics (PostHog)
# ============================================
# Get from: https://app.posthog.com → Project Settings → Project API Key
# Leave blank to disable analytics
NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
